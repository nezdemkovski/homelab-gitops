{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "timezone": "Europe/Prague",
  "dependencyDashboard": true,
  "ignorePaths": [
    "**/_disabled/**",
    "**/*.disabled"
  ],
  "labels": [
    "dependencies"
  ],
  "argocd": {
    "fileMatch": [
      "^apps/(?:infra|workloads)/.+/application\\.ya?ml$"
    ]
  },
  "kubernetes": {
    "fileMatch": [
      "^apps/(?:infra|workloads)/.+\\.ya?ml$"
    ]
  },
  "packageRules": [
    {
      "description": "Keep GitOps updates as reviewable pull requests",
      "matchManagers": [
        "argocd",
        "kubernetes"
      ],
      "automerge": false
    },
    {
      "description": "Require explicit dashboard approval for major infrastructure updates",
      "matchManagers": [
        "argocd",
        "kubernetes"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "dependencyDashboardApproval": true
    }
  ]
}
