{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "timezone": "Europe/Prague",
  "dependencyDashboard": true,
  "ignorePaths": [
    "**/_disabled/**",
    "**/*.disabled"
  ],
  "labels": [
    "dependencies"
  ],
  "argocd": {
    "fileMatch": [
      "^apps/(?:infra|workloads)/.+/application\\.ya?ml$"
    ]
  },
  "kubernetes": {
    "fileMatch": [
      "^apps/(?:infra|workloads)/.+\\.ya?ml$"
    ]
  },
  "helm-values": {
    "fileMatch": [
      "^charts/.+/values\\.ya?ml$"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track full imageName values used by Kubernetes operators",
      "fileMatch": [
        "^charts/.+/values\\.ya?ml$"
      ],
      "matchStrings": [
        "imageName:\\s*(?<depName>[^:\\s]+(?:/[^:\\s]+)+):(?<currentValue>[^\\s]+)"
      ],
      "datasourceTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "description": "Keep GitOps updates as reviewable pull requests",
      "matchManagers": [
        "argocd",
        "kubernetes",
        "helm-values",
        "custom.regex"
      ],
      "automerge": false
    },
    {
      "description": "Require explicit dashboard approval for major infrastructure updates",
      "matchManagers": [
        "argocd",
        "kubernetes",
        "helm-values",
        "custom.regex"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "dependencyDashboardApproval": true
    }
  ]
}
